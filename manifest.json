{
"manifest_version": 3,
  "name": "SiYuan Flashcard Tracker",
  "version": "1.3.2",
  "description": "Ein eleganter, performanter Tracker für gelernte Karteikarten in SiYuan Notes.",
  "author": "Hans-L-Max",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SiYuan Flashcard Tracker Statistiken"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "siyuan-flashcard-tracker@hans-l.de",
      "strict_min_version": "109.0",
      "data_collection_permissions": {}
    }
  }
}